{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "functions": {
    "server.js": { "includeFiles": "public/**" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/server.js" }
  ]
}